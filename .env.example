# Copy this file to .env. Never commit .env or any real credential.
# AUTH_MODE=mock is allowed only in development/test and is rejected in production.
# Application
APP_ENV=development
AUTH_MODE=mock
FRONTEND_ORIGIN=http://localhost:5173

# Local MySQL 8. Keep the real password only in the untracked .env file.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=kol_insight
MYSQL_USER=root
MYSQL_PASSWORD=

# Use a random value with at least 32 characters outside tests. Keep it only in .env.
JWT_SECRET=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30

# Phase two AI and DataTap settings. Keep real tokens only in .env.
# Any OpenAI-compatible provider works: set base URL, model name and key below.
# Tencent Token Plan (default): https://tokenhub.tencentmaas.com/plan/v3 + deepseek-v4-pro
# Moonshot Kimi example: TENCENT_PLAN_BASE_URL=https://api.moonshot.cn/v1, TENCENT_PLAN_MODEL=kimi-k2-0905-preview
TENCENT_PLAN_BASE_URL=https://tokenhub.tencentmaas.com/plan/v3
TENCENT_PLAN_MODEL=deepseek-v4-pro
TENCENT_PLAN_API_KEY=
MODEL_TIMEOUT_SECONDS=60
DATATAP_MCP_TOKEN=
DATATAP_READ_TIMEOUT_SECONDS=60
MCP_CALL_POINTS=10
MCP_UNKNOWN_RECONCILE_SECONDS=300
TASK_LEASE_SECONDS=60
