# Copy this file to .env. Never commit .env or any real credential.
# AUTH_MODE=mock is allowed only in development/test and is rejected in production.
# Application
APP_ENV=development
AUTH_MODE=mock
FRONTEND_ORIGIN=http://localhost:5173

# Local MySQL 8. Keep the real password only in the untracked .env file.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=kol_insight
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-local-password

# Use a random value with at least 32 characters outside tests.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30

# Reserved for later AI and DataTap integration phases. Keep real tokens only in .env.
MODEL_PROVIDER=mock
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=
DATATAP_MCP_URL=
DATATAP_MCP_TOKEN=
